[BOT]
TOKEN=
MUSIC_ENABLED=False
SPEECH_ENABLED=False
USE_EMBEDDED_COMFY=True
MAX_RETRIES=3
MAX_QUEUE_PER_USER=4

[LLM]
USE_LLM=False
# Gemma GGUF model used by TextGenerate for prompt enhancement (set USE_LLM=True per model section to enable)
CLIP_MODEL=gemma_3_12B_it_fp4_mixed.safetensors

[LOCAL]
SERVER_ADDRESS=http://127.0.0.1:8188
COMFY_ROOT_DIR=embedded_comfy

[EMBEDDED]
SERVER_PORT=8188

[SDXL_GENERATION_DEFAULTS]
MODEL=dreamshaperXL10_alpha2Xl10.safetensors
NUM_STEPS=8
CFG_SCALE=1.0
BATCH_SIZE=4
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
SAMPLER=euler_ancestral
INPAINTING_DETECTION_THRESHOLD=200
CLIP_SKIP=-2
ACCELERATOR_ENABLED=False
ACCELERATOR_LORA_NAME=xl\sdxl_lightning_4step_lora.safetensors
SCHEDULER=sgm_uniform
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=
DETAILING_CONTROLNET=XL/controlllite_xl_tile_realistic.safetensors
LLM_PROFILE=IF_PromptMKR
USE_TENSORRT=False
TENSORRT_MODEL=
CONTROLNET_MODEL=xl/controlnet-union-sdxl.safetensors

[SD15_GENERATION_DEFAULTS]
MODEL=rundiffusionFX_v10.safetensors
NUM_STEPS=20
CFG_SCALE=8.0
BATCH_SIZE=4
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
SAMPLER=ddim
INPAINTING_DETECTION_THRESHOLD=200
CLIP_SKIP=-2
LLM_PROFILE=IF_PromptMKR_IMG
USE_TENSORRT=False
TENSORRT_MODEL=

[SVD_GENERATION_DEFAULTS]
MODEL=svd/svd_xt_1_1.safetensors
NUM_STEPS=15
CFG_SCALE=2.5
BATCH_SIZE=1
SAMPLER=euler
SCHEDULER=karras
MIN_CFG=1
MOTION=50
AUGMENTATION=0
FPS=8
USE_ALIGN_YOUR_STEPS=True

[CASCADE_GENERATION_DEFAULTS]
MODEL=cascade/stable_cascade_stage_c.safetensors
NUM_STEPS=20
CFG_SCALE=4.0
BATCH_SIZE=4
SAMPLER=euler_ancestral
SCHEDULER=simple
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
LLM_PROFILE=IF_PromptMKR

[PONY_GENERATION_DEFAULTS]
MODEL=pony/ponyDiffusionV6.safetensors
NUM_STEPS=12
CFG_SCALE=2.0
BATCH_SIZE=4
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
SAMPLER=euler_ancestral
INPAINTING_DETECTION_THRESHOLD=200
CLIP_SKIP=-2
ACCELERATOR_ENABLED=False
ACCELERATOR_LORA_NAME=xl/sdxl_lightning_4step_lora.safetensors
SCHEDULER=normal
DEFAULT_STYLE_PROMPT=score_9, score_8_up, score_7_up, score_6_up, score_5_up
DEFAULT_NEGATIVE_STYLE_PROMPT=worst quality, bad quality, low quality, deformed, blurry, censored, bad anatomy, watermark, signature, bad artist, lowres, missing limbs, missing hands, missing fingers, extra fingers, extra hands, extra digits, malformed face, loli, kid, kids, children
VAE=pony/pony_vae.safetensors
DETAILING_CONTROLNET=pony/bdsqlsz_controlllite_xl_tile_anime.safetensors
LLM_PROFILE=IF_PromptMKR_IMG
CONTROLNET_MODEL=xl/controlnet-union-sdxl.safetensors

[SD3_GENERATION_DEFAULTS]
MODEL=sd3/sd3_medium.safetensors
NUM_STEPS=20
CFG_SCALE=5
BATCH_SIZE=4
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
SAMPLER=dpmpp_2m
INPAINTING_DETECTION_THRESHOLD=200
CLIP_SKIP=-1
ACCELERATOR_ENABLED=False
SCHEDULER=sgm_uniform
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=
DETAILING_CONTROLNET=
LLM_PROFILE=IF_PromptMKR
USE_ALIGN_YOUR_STEPS=False
USE_TENSORRT=False
TENSORRT_MODEL=

[FLUX_GENERATION_DEFAULTS]
MODEL=flux/FLUXMODEL.safetensors
NUM_STEPS=50
CFG_SCALE=1
BATCH_SIZE=4
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
SAMPLER=euler
INPAINTING_DETECTION_THRESHOLD=200
CLIP_SKIP=-1
ACCELERATOR_ENABLED=False
SCHEDULER=simple
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=
DETAILING_CONTROLNET=
LLM_PROFILE=IF_PromptMKR
USE_ALIGN_YOUR_STEPS=False
USE_TEACACHE=False
USE_TRITON=False
USE_TENSORRT=False
TENSORRT_MODEL=
MASHUP_IMAGE1_STRENGTH=1
MASHUP_IMAGE2_STRENGTH=1
CONTROLNET_MODEL=flux/FLUX-controlnet-Union-Pro.safetensors

[FLUX2_GENERATION_DEFAULTS]
MODEL= flux2-klein-4b-fp8.safetensors
NUM_STEPS=4
CFG_SCALE=1
BATCH_SIZE=4
ASPECT_RATIO=1:1
DENOISE_STRENGTH=0.8
SAMPLER=euler
INPAINTING_DETECTION_THRESHOLD=200
CLIP_SKIP=-1
SCHEDULER=simple
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=
DETAILING_CONTROLNET=
LLM_PROFILE=
ACCELERATOR_ENABLED=False
USE_ALIGN_YOUR_STEPS=False
USE_TEACACHE=False
USE_TRITON=False
USE_TENSORRT=False
TENSORRT_MODEL=
MASHUP_IMAGE1_STRENGTH=1
MASHUP_IMAGE2_STRENGTH=1
CLIP_MODEL=qwen_3_4b_fp4_flux2.safetensors

[KONTEXT_DEFAULTS]
MODEL=flux_kontext/flux-kontext-dev.safetensors
ASPECT_RATIO=1:1
NUM_STEPS=20
CFG_SCALE=2.5
BATCH_SIZE=1
DENOISE_STRENGTH=1
SAMPLER=euler
CLIP_SKIP=-1
ACCELERATOR_ENABLED=False
SCHEDULER=simple
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=
DETAILING_CONTROLNET=
LLM_PROFILE=
USE_ALIGN_YOUR_STEPS=False
USE_TEACACHE=True
USE_TRITON=True
USE_TENSORRT=False
TENSORRT_MODEL=
CONTROLNET_MODEL=FLUX-controlnet-Union-Pro.safetensors

[EDIT_DEFAULTS]
MODEL=flux2-klein-4b-fp8.safetensors
NUM_STEPS=20
CFG_SCALE=5
BATCH_SIZE=1
ASPECT_RATIO=1:1
DENOISE_STRENGTH=1
SAMPLER=euler
CLIP_SKIP=-1
ACCELERATOR_ENABLED=False
SCHEDULER=simple
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=
DETAILING_CONTROLNET=
LLM_PROFILE=
USE_ALIGN_YOUR_STEPS=False
USE_TEACACHE=False
USE_TRITON=True
USE_TENSORRT=False
TENSORRT_MODEL=
CLIP_MODEL=qwen_3_4b_fp4_flux2.safetensors

[WAN_GENERATION_DEFAULTS]
MODEL=Wan2.2-TI2V-5B-Q8_0.gguf
NUM_STEPS=30
CFG_SCALE=5
BATCH_SIZE=1
SAMPLER=uni_pc
SCHEDULER=simple
FPS=24
USE_TEACACHE=True
USE_TRITON=True
USE_DISTILLED_LORA=False
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走
VIDEO_WIDTH=640
VIDEO_LENGTH=121
CLIP_MODEL=umt5-xxl-encoder-Q5_K_M.gguf
VAE=wan2.2_vae.safetensors

[IMAGE_WAN_GENERATION_DEFAULTS]
MODEL=Wan2.2-TI2V-5B-Q8_0.gguf
NUM_STEPS=30
CFG_SCALE=5
BATCH_SIZE=1
SAMPLER=uni_pc
SCHEDULER=simple
FPS=24
MAX_WIDTH=480
USE_TEACACHE=True
USE_TRITON=False
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走
VIDEO_LENGTH=121
CLIP_MODEL=umt5-xxl-encoder-Q5_K_M.gguf
CROP_IMAGE=True
VAE=wan2.2_vae.safetensors

[LTX_GENERATION_DEFAULTS]
# UNET: download from https://huggingface.co/Lightricks/LTX-Video-2.3
MODEL=ltx/ltx-2.3-22b-dev-Q3_K_M.gguf
# Text encoder (Gemma) + text projection (both required for DualCLIPLoader)
CLIP_MODEL=gemma_3_12B_it_fp4_mixed.safetensors
CLIP_MODEL2=ltx/ltx-2.3_text_projection_bf16.safetensors
# Separate video and audio VAEs
VAE=ltx/ltx-2.3-22b-dev_video_vae.safetensors
AUDIO_VAE=ltx/ltx-2.3-22b-dev_audio_vae.safetensors
# Spatial upscaler for two-pass pipeline
LATENT_UPSCALE_MODEL=ltx/ltx-2.3-spatial-upscaler-x2-1.1.safetensors
# Distilled LoRA (applied model-only at strength 0.6)
ACCELERATOR_ENABLED=True
ACCELERATOR_LORA_NAME=ltx/ltx-2.3-22b-distilled-lora-dynamic_fro09_avg_rank_105_bf16.safetensors
CFG_SCALE=1.0
BATCH_SIZE=1
FPS=24
VIDEO_WIDTH=768
# Default duration for /ltx and /video: short, medium, or long
DEFAULT_DURATION=medium
DURATION_SHORT=7
DURATION_MEDIUM=10
DURATION_LONG=14
DEFAULT_STYLE_PROMPT=
DEFAULT_NEGATIVE_STYLE_PROMPT=blurry, low quality, still frame, frames, watermark, overlay, titles, has blurbox, has subtitles
# When True, loads system prompt from prompts/ltx_t2v_system_prompt.txt or prompts/ltx_i2v_system_prompt.txt
# and disables the node's built-in template (use_default_template=False)
USE_CUSTOM_SYSTEM_PROMPT=False

[ADD_DETAIL_DEFAULTS]
DENOISE_STRENGTH=0.3
BATCH_SIZE=1
DETAILING_CONTROLNET_STRENGTH=0.5
DETAILING_CONTROLNET_END_PERCENT=1

[UPSCALE_DEFAULTS]
MODEL=RealESRGAN_x4plus.pth

[MUSICGEN_DEFAULTS]
DURATION=10.0
CFG=3.0
TOP_K=250
TOP_P=0.0
TEMPERATURE=1.0

[TORTOISE_DEFAULTS]
TOP_P=0.8
TEMPERATURE=0.3
VOICE=random

[NSFW_DETECTION]
NSFW_DETECTION_ENABLED=False
# Set to `None` to disable this layer of detection
NUDE_DETECTOR_MODEL_PATH=data/640m.onnx
NUDE_DETECTOR_INFERENCE_RESOLUTION=640
NUDE_DETECTOR_CLASS_BLACKLIST=ANUS_COVERED,ANUS_EXPOSED,BUTTOCKS_EXPOSED,FEMALE_BREAST_EXPOSED,FEMALE_GENITALIA_EXPOSED,MALE_GENITALIA_EXPOSED
NSFW_TERM_BLACKLIST=ANUS,ASS,ASSHOLE,BALLS,BREAST,BREASTS,BOLLOCKS,BONER,BOOB,BOOBS,BUTT,BUTTHOLE,CLIT,COCK,COCKS,CUM,CUMMING,CUNT,DICK,DICKS,ERECTION,NIPPLE,NIPPLES,NUDE,ORGASM,ORGY,PENIS,PENISES,PHALLUS,PISS,PORN,PORNO,PUSSY,PUSSIES,SEMEN,SEX,SHIT,SHITS,TESTICLE,TESTICLES,TIT,TITS,VAGINA,VAGINAS,VULVA,VULVAS

[BLOCKED_WORDS]
WORDS=KIDS,KID,CHILDREN,CHILD,LOLI
